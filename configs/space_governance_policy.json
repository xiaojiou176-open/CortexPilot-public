  "process_groups": {
    "node": {
      "patterns": [
        "\\bnode\\b",
        "\\bpnpm\\b",
        "\\bnext\\b",
        "\\bvite\\b",
        "\\bvitest\\b"
      ]
    },
    "python": {
      "patterns": [
        "\\bpython(3(\\.\\d+)?)?\\b",
        "\\buv\\b",
        "\\bpytest\\b"
      ]
    },
    "playwright": {
      "patterns": [
        "playwright",
        "chromium",
        "webkit",
        "firefox"
      ]
    },
    "cargo": {
      "patterns": [
        "\\bcargo\\b",
        "\\brustc\\b",
        "\\brustup\\b"
      ]
    },
    "tauri": {
      "patterns": [
        "\\btauri\\b"
      ]
    },
    "docker": {
      "patterns": [
        "\\bdocker\\b",
        "containerd",
        "buildkit"
      ]
    }
  },
