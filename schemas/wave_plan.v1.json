{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/wave_plan.v1.json",
  "title": "WavePlan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "wave_id",
    "objective",
    "owner_agent",
    "execution_mode",
    "wake_policy_ref",
    "completion_policy_ref",
    "worker_count",
    "worker_plans"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "v1"
    },
    "wave_id": {
      "type": "string",
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "owner_agent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "agent_id"
      ],
      "properties": {
        "role": {
          "type": "string",
          "minLength": 1
        },
        "agent_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "execution_mode": {
      "type": "string",
      "enum": [
        "long_running"
      ]
    },
    "wake_policy_ref": {
      "type": "string",
      "minLength": 1
    },
    "completion_policy_ref": {
      "type": "string",
      "minLength": 1
    },
    "worker_count": {
      "type": "integer",
      "minimum": 1
    },
    "worker_plans": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "prompt_contract_id",
          "assigned_role",
          "spec",
          "allowed_paths",
          "acceptance_checks",
          "mcp_tools"
        ],
        "properties": {
          "prompt_contract_id": {
            "type": "string",
            "minLength": 1
          },
          "assigned_role": {
            "type": "string",
            "minLength": 1
          },
          "spec": {
            "type": "string",
            "minLength": 1
          },
          "allowed_paths": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "acceptance_checks": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "mcp_tools": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
