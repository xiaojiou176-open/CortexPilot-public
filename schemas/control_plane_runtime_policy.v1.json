{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/control_plane_runtime_policy.v1.json",
  "title": "ControlPlaneRuntimePolicy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "product_identity",
    "hierarchy_axis",
    "role_axis",
    "session_policy",
    "wake_policy",
    "wave_completion_policy",
    "planner_artifacts",
    "completion_governance",
    "unblock_policy",
    "harness_evolution",
    "external_write_policy",
    "portfolio_priority_formula",
    "first_class_entities",
    "front_door_story"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "v1"
    },
    "product_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "one_sentence",
        "primary_execution_bases",
        "reference_only_systems"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "one_sentence": {
          "type": "string",
          "minLength": 1
        },
        "primary_execution_bases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reference_only_systems": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "hierarchy_axis": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "enum": [
          "L0",
          "L1",
          "L2"
        ]
      }
    },
    "role_axis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model",
        "examples",
        "customizable"
      ],
      "properties": {
        "model": {
          "type": "string",
          "const": "work_type"
        },
        "examples": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "customizable": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "session_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default_mode",
        "context_pack_mode",
        "degradation_signals",
        "degradation_responses",
        "context_pack_triggers"
      ],
      "properties": {
        "default_mode": {
          "type": "string",
          "const": "long_running"
        },
        "context_pack_mode": {
          "type": "string",
          "const": "fallback_only"
        },
        "degradation_signals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "repetition",
              "half_done_report",
              "context_contamination"
            ]
          }
        },
        "degradation_responses": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "repetition",
            "half_done_report",
            "context_contamination"
          ],
          "properties": {
            "repetition": {
              "type": "string",
              "enum": [
                "corrective_reprompt"
              ]
            },
            "half_done_report": {
              "type": "string",
              "enum": [
                "structured_self_check"
              ]
            },
            "context_contamination": {
              "type": "string",
              "enum": [
                "handoff_or_new_session"
              ]
            }
          }
        },
        "context_pack_triggers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "context_pressure",
              "contamination",
              "role_switch",
              "phase_switch",
              "repetition",
              "distortion"
            ]
          }
        }
      }
    },
    "wake_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary_mode",
        "fallback_mode",
        "active_wave_interval_seconds",
        "idle_interval_min_seconds",
        "idle_interval_max_seconds"
      ],
      "properties": {
        "primary_mode": {
          "type": "string",
          "const": "event_driven"
        },
        "fallback_mode": {
          "type": "string",
          "const": "polling"
        },
        "active_wave_interval_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "idle_interval_min_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "idle_interval_max_seconds": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "wave_completion_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requires_all_workers_complete",
        "requires_no_open_blockers",
        "final_closeout_authority"
      ],
      "properties": {
        "requires_all_workers_complete": {
          "type": "boolean"
        },
        "requires_no_open_blockers": {
          "type": "boolean"
        },
        "final_closeout_authority": {
          "type": "string",
          "enum": [
            "upper_layer_verdict"
          ]
        }
      }
    },
    "planner_artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tier_1",
        "tier_2"
      ],
      "properties": {
        "tier_1": {
          "type": "string",
          "const": "wave_plan"
        },
        "tier_2": {
          "type": "string",
          "const": "worker_prompt_contract"
        }
      }
    },
    "completion_governance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "components",
        "task_type_layered"
      ],
      "properties": {
        "components": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string",
            "enum": [
              "dod_checker",
              "reply_auditor",
              "continuation_policy"
            ]
          }
        },
        "task_type_layered": {
          "type": "boolean"
        }
      }
    },
    "unblock_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "owner"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "const": "independent_temporary_task"
        },
        "owner": {
          "type": "string",
          "const": "L0"
        }
      }
    },
    "harness_evolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "session_local_auto",
        "project_local_requires_approval",
        "global_requires_approval",
        "project_local_approval_mode",
        "global_approval_mode"
      ],
      "properties": {
        "session_local_auto": {
          "type": "boolean"
        },
        "project_local_requires_approval": {
          "type": "boolean"
        },
        "global_requires_approval": {
          "type": "boolean"
        },
        "project_local_approval_mode": {
          "type": "string",
          "enum": [
            "human_or_rule"
          ]
        },
        "global_approval_mode": {
          "type": "string",
          "enum": [
            "high_barrier"
          ]
        }
      }
    },
    "external_write_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "whitelist_systems",
        "github_whitelist_actions",
        "non_whitelist_requires_approval"
      ],
      "properties": {
        "whitelist_systems": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "github_whitelist_actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "comment",
              "issue",
              "branch",
              "pull_request",
              "merge"
            ]
          }
        },
        "non_whitelist_requires_approval": {
          "type": "boolean"
        }
      }
    },
    "portfolio_priority_formula": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "string",
        "enum": [
          "user_priority",
          "blocker_risk",
          "deadline",
          "resource_fairness"
        ]
      }
    },
    "first_class_entities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "Objective",
          "Wave",
          "Role",
          "Session",
          "Run",
          "Workflow Case",
          "Context Pack",
          "Prompt Artifact",
          "Harness Request",
          "Unblock Task",
          "Approval"
        ]
      }
    },
    "front_door_story": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "subtitle_actions",
        "pain_statement",
        "philosophy"
      ],
      "properties": {
        "title": {
          "type": "string",
          "const": "The command tower for AI engineering"
        },
        "subtitle_actions": {
          "type": "array",
          "minItems": 5,
          "items": {
            "type": "string",
            "enum": [
              "plan",
              "delegate",
              "track",
              "resume",
              "prove"
            ]
          }
        },
        "pain_statement": {
          "type": "string",
          "minLength": 1
        },
        "philosophy": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string",
            "enum": [
              "Prompt Engineering",
              "Context Engineering",
              "Harness Engineering"
            ]
          }
        }
      }
    }
  }
}
