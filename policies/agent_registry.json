{
  "version": "v1",
  "agents": [
    {
      "agent_id": "agent-1",
      "role": "WORKER",
      "codex_home": "$HOME/.codex-homes/cortexpilot-worker-core",
      "defaults": {
        "sandbox": "workspace-write",
        "approval_policy": "never",
        "network": "deny"
      },
      "capabilities": {
        "mcp_tools": [
          "01-filesystem",
          "codex",
          "sampling",
          "aider",
          "continue",
          "open_interpreter"
        ],
        "notes": "default worker"
      }
    },
    {
      "agent_id": "agent-1",
      "role": "REVIEWER",
      "codex_home": "$HOME/.codex-homes/cortexpilot-reviewer",
      "defaults": {
        "sandbox": "read-only",
        "approval_policy": "never",
        "network": "deny"
      },
      "capabilities": {
        "mcp_tools": [
          "codex"
        ],
        "notes": "reviewer requires codex for MCP gate compatibility"
      }
    },
    {
      "agent_id": "agent-1",
      "role": "TEST_RUNNER",
